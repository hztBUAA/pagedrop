# Multi-stage: build the Vue product app and the React renderer, then serve both
# (plus reverse-proxy the API) from a single Caddy image.
#
# Build context must be the repository root:
#   docker build -f infra/Dockerfile.web -t pagedrop-web .

# --- Stage 1: build the Vue product app ---
FROM node:22-slim AS web-vue
RUN npm install -g pnpm@11
WORKDIR /build
COPY apps/web-vue/package.json apps/web-vue/pnpm-lock.yaml apps/web-vue/pnpm-workspace.yaml apps/web-vue/.npmrc ./
# strictDepBuilds=false lets install exit cleanly; approve-builds runs the
# allow-listed native builds (esbuild, vue-demi) non-interactively.
RUN pnpm install --frozen-lockfile --config.strictDepBuilds=false \
    && pnpm approve-builds --all
COPY apps/web-vue/ ./
# Renderer is served at /render/ in production (same origin).
ENV VITE_RENDERER_URL=/render/
RUN pnpm build

# --- Stage 2: build the React renderer ---
FROM node:22-slim AS renderer
RUN npm install -g pnpm@11
WORKDIR /build
COPY apps/renderer-react/package.json apps/renderer-react/pnpm-lock.yaml apps/renderer-react/pnpm-workspace.yaml apps/renderer-react/.npmrc ./
RUN pnpm install --frozen-lockfile --config.strictDepBuilds=false \
    && pnpm approve-builds --all
COPY apps/renderer-react/ ./
RUN pnpm build

# --- Stage 3: Caddy serving static assets + reverse-proxying the API ---
FROM caddy:2-alpine
COPY infra/Caddyfile /etc/caddy/Caddyfile
COPY --from=web-vue /build/dist /srv/web
COPY --from=renderer /build/dist /srv/render
