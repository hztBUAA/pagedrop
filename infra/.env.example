# --- PostgreSQL (production) ---
POSTGRES_USER=pagedrop
POSTGRES_PASSWORD=change-me
POSTGRES_DB=pagedrop

# Backend database DSN.
# Local dev without Postgres can use: sqlite:///./pagedrop.db
DATABASE_URL=postgresql+psycopg://pagedrop:change-me@postgres:5432/pagedrop

# --- Security ---
JWT_SECRET=change-me-to-a-long-random-string
TOKEN_PEPPER=change-me-to-another-long-random-string
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# --- App ---
APP_BASE_URL=https://pagedrop.justinhuang.top
CORS_ORIGINS=https://pagedrop.justinhuang.top
DEBUG=false

# --- Email / SMTP (verification codes) ---
# QQ mail example: host smtp.qq.com, port 465 (SSL). SMTP_AUTH_CODE is the
# provider's authorization code, NOT your account password. SMTP_FROM defaults
# to SMTP_USER when empty. Leave user/code empty to disable email sending.
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_AUTH_CODE=
SMTP_FROM=

# --- OAuth (leave blank to disable a provider) ---
# GitHub OAuth App with Device Flow enabled. Register at
# https://github.com/settings/developers — Homepage URL and Authorization
# callback URL below. Client secret is only needed for the web (auth-code) flow.
#   Homepage URL:              https://pagedrop.justinhuang.top
#   Authorization callback URL: https://pagedrop.justinhuang.top/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google OAuth 2.0 client (Google Cloud Console → APIs & Services → Credentials).
#   Authorized redirect URI:   https://pagedrop.justinhuang.top/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Reverse proxy (Caddy) ---
# Public address Caddy binds to. Use the domain for automatic HTTPS in
# production, or ":80" for a plain-HTTP local test of the stack.
SITE_ADDRESS=pagedrop.justinhuang.top
